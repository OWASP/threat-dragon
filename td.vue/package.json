{
  "name": "threat-dragon",
  "productName": "Threat Dragon",
  "version": "2.6.2",
  "appBundleId": "org.owasp.threatdragon",
  "private": true,
  "scripts": {
    "prebuild:desktop": "node ./src/plugins/generate-cornucopia.js",
    "prestart:desktop": "node ./src/plugins/generate-cornucopia.js",
    "audit": "npm audit",
    "prebuild": "node ./src/plugins/generate-cornucopia.js",
    "build": "vue-cli-service build --no-unsafe-inline",
    "build:desktop": "vue-cli-service electron:build",
    "make-sbom": "node -e 'console.log(`SBOMs are build automatically during build process - see build result folder: .sbom`)'",
    "clean": "rimraf coverage/ cypress/ dist/ dist-desktop/ node_modules/ tests/e2e/videos/ tests/e2e/reports/ tests/e2e/screenshots/ log/ results/",
    "cypress:open": "cypress open",
    "cypress:update": "npx update-browserslist-db@latest",
    "predev": "node ./src/plugins/generate-cornucopia.js",
    "dev": "vue-cli-service serve",
    "lint": "vue-cli-service lint --fix",
    "lint:desktop": "vue-cli-service lint src/desktop tests/unit/desktop",
    "pretest": "npm run lint && npm run lint:desktop && node ./src/plugins/generate-cornucopia.js",
    "serve": "vue-cli-service serve",
    "start": "echo 'Please run the start command from the root of this repository' && exit 1",
    "start:desktop": "vue-cli-service electron:serve",
    "prestart:serve": "node ./src/plugins/generate-cornucopia.js",
    "start:serve": "pm2 --name td.vue start 'vue-cli-service serve'",
    "stop:serve": "pm2 delete td.vue",
    "pretest:unit": "node ./src/plugins/generate-cornucopia.js",
    "test": "vue-cli-service test:unit",
    "test:desktop": "vue-cli-service test:unit --testMatch '**/tests/unit/desktop/**/*.spec.js' --collectCoverageFrom 'src/desktop/**/*.js'",
    "test:e2e": "vue-cli-service test:e2e -C e2e.local.config.js",
    "test:e2e:desktop": "mocha --require ./tests/e2e/desktop/support/setup.js \"./tests/e2e/desktop/specs/*.spec.js\"",
    "test:e2e:local": "vue-cli-service test:e2e -C e2e.local.config.js --url http://localhost:8080/",
    "test:e2e-ci": "vue-cli-service test:e2e  -C e2e.ci.config.js --browser chromium --headless --url http://localhost:3000/",
    "test:e2e-ci-smokes": "vue-cli-service test:e2e -C e2e.smokes.ci.config.js --browser chromium --headless --url http://localhost:3000/",
    "test:e2e-pr": "vue-cli-service test:e2e  -C e2e.ci.config.js --browser chromium --headless --url http://localhost:8080/",
    "pretest:e2e-pr-smokes": "node ./src/plugins/generate-cornucopia.js",
    "test:e2e-pr-smokes": "vue-cli-service test:e2e -C e2e.smokes.ci.config.js --browser chromium --headless --url http://localhost:8080/",
    "test:visual": "vue-cli-service test:e2e -C e2e.visual.config.js --browser chrome --headless",
    "test:visual:update": "vue-cli-service test:e2e -C e2e.visual.config.js --browser chrome --headless --env updateSnapshots=true",
    "test:e2e-smokes": "browserstack-cypress run --cf browserstack.smokes.json --sync",
    "test:e2e-smokes:local": "vue-cli-service test:e2e -C e2e.smokes.local.config.js --url http://localhost:8080/",
    "test:e2e-nightly": "browserstack-cypress run --cf browserstack.nightly.json --sync",
    "test:unit": "vue-cli-service test:unit --testPathIgnorePatterns tests/unit/desktop/",
    "test:vue": "vue-cli-service test:e2e -C e2e.local.config.js --headless --browser chrome"
  },
  "description": "OWASP Threat Dragon - a free, open source threat modeling tool",
  "author": {
    "name": "OWASP Threat Dragon",
    "email": "threat-dragon-project@owasp.org",
    "url": "https://owasp.org/www-project-threat-dragon/"
  },
  "license": "Apache-2.0",
  "engines": {
    "npm": ">=11.10.0"
  },
  "homepage": "https://owasp.org/www-project-threat-dragon/",
  "buildState": "-latest",
  "repository": {
    "type": "git",
    "url": "git://github.com/OWASP/threat-dragon.git"
  },
  "bugs": {
    "email": "threat-dragon-project@owasp.org",
    "url": "https://github.com/OWASP/threat-dragon/issues"
  },
